# ─────────────────────────────────────────────
# Anamnesis Telegram bot token
# 跟 Pharos bot 分開、需要去 @BotFather 建一個獨立 bot
# ─────────────────────────────────────────────
OBSIDIAN_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# Gemini — 書籍 overview / vocab tag / chat / quiz / 影片摘要 全用這個
# 取得：https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────
# Dropbox API（server 端必要、Mac 桌面 client 用戶可省略）
# 跟 Pharos 共用同一個 Dropbox app（Full Dropbox 權限）
# ─────────────────────────────────────────────
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# ─────────────────────────────────────────────
# Daily review digest 時間（24h, default 22）
# ─────────────────────────────────────────────
# DAILY_REVIEW_DIGEST_HOUR=22

# ─────────────────────────────────────────────
# Vault paths（預設足夠、要客制化才設）
# ─────────────────────────────────────────────
# DROPBOX_KOBO_HIGHLIGHTS_PATH=/Kobo Highlights
# DROPBOX_OBSIDIAN_INBOX_PATH=/Greens Obsidian/0 Inbox
# DROPBOX_VAULT_BOOKS_PATH=/Greens Obsidian/1 Sources/Books
# DROPBOX_VAULT_INTERVIEWS_PATH=/Greens Obsidian/1 Sources/Interviews
# DROPBOX_VAULT_HIGHLIGHTS_PATH=/Greens Obsidian/1 Sources/Highlights
# DROPBOX_VAULT_QUIZZES_PATH=/Greens Obsidian/2 Atomic Notes/Quizzes
# DROPBOX_VAULT_CONVERSATIONS_PATH=/Greens Obsidian/2 Atomic Notes/Conversations
